{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "python": {
    "version": "3.11"
  },
  "functions": {
    "backend/api.py": {
      "runtime": "python3.11",
      "memory": 3008,
      "maxDuration": 120,
      "includeFiles": "backend/**",
      "excludeFiles": "backend/.venv/**,backend/__pycache__/**,backend/uploads/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/api"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/backend/uploads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ],
  "env": {
    "PYTHONPATH": "./backend",
    "PYTHONUNBUFFERED": "1"
  }
}
